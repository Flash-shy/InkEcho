# Copy to .env and adjust. Used by compose + local apps.

# PostgreSQL (docker compose) — only needed when using Postgres instead of SQLite
POSTGRES_USER=inkecho
POSTGRES_PASSWORD=inkecho
POSTGRES_DB=inkecho
# Backend: default in code is SQLite under apps/backend/data/ (no Docker).
# For Docker Postgres after `docker compose up -d`, set e.g.:
# DATABASE_URL=postgresql://inkecho:inkecho@localhost:5432/inkecho
DATABASE_URL=sqlite+aiosqlite:///./data/inkecho.db

# MinIO (S3-compatible, docker compose)
MINIO_ROOT_USER=inkecho
MINIO_ROOT_PASSWORD=inkecho_minio_dev
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=ink-echo

# Backend
BACKEND_CORS_ORIGINS=http://localhost:5173
BACKEND_PORT=8000
# GET /health/platform probes this URL (Vite dev server by default).
FRONTEND_PUBLIC_URL=http://127.0.0.1:5173
# MCP HTTP /health (see INK_ECHO_MCP_HEALTH_PORT on mcp-server); must match where MCP listens.
MCP_HEALTH_URL=http://127.0.0.1:3033/health
AI_API_BASE_URL=http://127.0.0.1:8001
AI_API_SERVICE_TOKEN=dev-change-me
# Max audio/video upload per request in bytes (default 512 MiB if unset)
# MAX_UPLOAD_BYTES=536870912
# Cross-session RAG: transcript chunk size (characters) for indexing
# RAG_CHUNK_MAX_CHARS=900

# AI-API
AI_API_PORT=8001
# Speech-to-text: auto | openai | openrouter
# auto: use OpenAI if OPENAI_API_KEY is set, else OpenRouter if OPENROUTER_API_KEY, else mock.
STT_PROVIDER=auto
# Chat / summarization (same keys as STT): auto | openai | openrouter
CHAT_PROVIDER=auto
# RAG embeddings on AI-API: auto | openai | openrouter (mock vectors if no key / ollama without key on official OpenAI host)
EMBED_PROVIDER=auto
OPENAI_EMBED_MODEL=text-embedding-3-small
# Avoid openai/* on OpenRouter for embeddings (often 403 provider ToS). Pick an id from:
# https://openrouter.ai/models?output_modalities=embeddings
OPENROUTER_EMBED_MODEL=intfloat/e5-base-v2
# MOCK_EMBED_DIMENSIONS=256
OPENAI_CHAT_MODEL=gpt-4o-mini
# Default avoids openai/* on OpenRouter (often 403 “ToS” from OpenAI regional rules). Override on openrouter.ai/models.
OPENROUTER_CHAT_MODEL=mistralai/mistral-small-3.2-24b-instruct
# Summarize fully offline: Ollama + OpenAI-compatible API (then CHAT_PROVIDER=auto or openai, no cloud key needed):
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_CHAT_MODEL=llama3.2
# OPENAI_API_KEY=
# OpenAI Whisper (native /audio/transcriptions)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenRouter: chat/completions + input_audio (pick an audio-in model on OpenRouter’s model list)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Audio-input model: https://openrouter.ai/models — default Mistral Voxtral (often fewer403s than Google/OpenAI routes).
OPENROUTER_TRANSCRIBE_MODEL=mistralai/voxtral-small-24b-2507
OPENROUTER_HTTP_REFERER=https://openrouter.ai
OPENROUTER_X_TITLE=InkEcho

# Web (Vite)
VITE_BACKEND_URL=http://127.0.0.1:8000

# MCP server
INK_ECHO_SKILLS_DIR=
INK_ECHO_BACKEND_URL=http://127.0.0.1:8000
INK_ECHO_MCP_BACKEND_TOKEN=
# HTTP /health for platform status (default 3033). Set to 0 to disable (stdio MCP still works; status will show MCP down).
INK_ECHO_MCP_HEALTH_PORT=3033
